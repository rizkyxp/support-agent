# === GitHub AI Agent Configuration ===

# 🔑 Authentication
# This agent relies entirely on CLI authentication. You MUST be logged in via:
# 1. GitHub CLI: `gh auth login`
# 2. Gemini CLI: `gemini auth login` (or potentially `gcloud auth login` if applicable)

# 🤖 Client Configuration
GEMINI_CLI_PATH=gemini
GEMINI_CLI_MODEL=gemini-3-flash
GITHUB_CLI_PATH=gh

# 📂 Repository Settings
GITHUB_ORGANIZATION=your_org_name
REPOSITORIES_DIR=.repositories
DEFAULT_TARGET_BASE_BRANCH=main

# ⚙️ Processing Modes
PROCESS_ISSUES=true
PROCESS_PRS=true
AUTO_REQUEST_REVIEW=true

# 🛡️ Change Protection Settings (HITL)
# Enable/disable the change protection system
CHANGE_PROTECTION_ENABLED=true

# Protection mode: 
# "halt" - (Recommended) Stops the agent if a protection violation is detected (Human-in-the-Loop).
# "warn" - Logs a warning but continues with the process.
CHANGE_PROTECTION_MODE=halt

# Enable dry-run mode (preview changes without pushing)
DRY_RUN_MODE=false

# Include PR diff in Gemini prompt for context (helps prevent reverts)
INCLUDE_PR_DIFF_IN_PROMPT=true

# Maximum PR diff size to include in prompt (characters)
MAX_PR_DIFF_SIZE=50000

# 📝 Note: Settings in the Dashboard Control Panel (SQLite) will override these defaults.
# The dashboard gives you FULL Control to override any environment variable here.
