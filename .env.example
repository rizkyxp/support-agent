# ============================================
# GitHub AI Agent Configuration
# ============================================

# --------------------------------------------
# REQUIRED
# --------------------------------------------

# GitHub Organization Name (OPTIONAL - reads all orgs if not set)
# Leave empty or comment out to monitor all organizations you have access to
# GITHUB_ORGANIZATION=your_organization_name

# Use Gemini CLI (default: true)
USE_GEMINI_CLI=true

# Use GitHub CLI (default: true)
USE_GITHUB_CLI=true

# --------------------------------------------
# SETTINGS
# --------------------------------------------

# Check interval in seconds (default: 300 = 5 minutes)
# Set to 0 for single run mode
CHECK_INTERVAL=300

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Target branch for Pull Requests
DEFAULT_TARGET_BASE_BRANCH=main

# Directory to store cloned repositories (default: .repositories)
# This folder will be created in the project root and is git-ignored
REPOSITORIES_DIR=.repositories

# ============================================
# QUICK START
# ============================================
#
# 1. Install CLI tools:
#    brew install gh
#    npm install -g @google/generative-ai-cli
#
# 2. Authenticate:
#    gh auth login
#    gemini auth login
#
# 3. Copy this file to .env:
#    cp .env.example .env
#
# 4. (Optional) Edit .env to set specific organization:
#    GITHUB_ORGANIZATION=your-org-name
#    (Leave unset to monitor all organizations)
#
# 5. Run:
#    python3 -m src.main
#
# ============================================
